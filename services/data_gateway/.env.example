# ==============================================================================
# data_gateway — Auth + User Management + Naipunyam Bridge
# ==============================================================================
# Owns: Authentication (pluggable), user CRUD, role mgmt, Naipunyam SSO + sync
# Run:  cd services/data_gateway && uvicorn app.main:app --reload --port 8002
# Copy this file to .env and fill in real values. NEVER commit .env.
# ==============================================================================

# --- Service identity ---
SERVICE_NAME=data_gateway
APP_ENV=development
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=8002

# --- Database (Postgres) ---
# Local dev:  docker-compose Postgres
# Demo:       Neon  (postgresql+asyncpg://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/intants?sslmode=require)
# Production: AWS RDS Mumbai
DATABASE_URL=postgresql+asyncpg://intants:intants_dev_pw@localhost:5433/intants_interview
DATABASE_POOL_SIZE=10
# Set to "require" for any cloud/TLS endpoint (Prisma, Neon, RDS).
# asyncpg rejects ?sslmode= query params — SSL is passed via connect_args instead.
# Leave blank for local docker-compose Postgres.
DATABASE_SSL=

# --- Cache (Redis) ---
# Local dev:  docker-compose Redis
# Demo:       Upstash  (rediss://default:pass@xxx.upstash.io:6379/1)
# Production: AWS ElastiCache Mumbai
REDIS_URL=redis://localhost:6379/1

# --- Auth Provider — THE SWAPPABLE LAYER ---
AUTH_PROVIDER=local                             # local | google | keycloak | naipunyam

# Local JWT (this service ISSUES tokens; other services validate)
JWT_SECRET=change-me-to-random-64-char-hex
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7
PASSWORD_HASH_ROUNDS=12
# S3-005: required claims embedded in every issued token
JWT_ISSUER=intants-data-gateway
JWT_AUDIENCE=intants-services

# Google OAuth (sign in with Google)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8002/auth/google/callback

# Keycloak (enterprise SSO)
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=

# Naipunyam (govt SAML — fill on integration day)
NAIPUNYAM_SAML_METADATA_URL=
NAIPUNYAM_SAML_ENTITY_ID=
NAIPUNYAM_SAML_ACS_URL=
NAIPUNYAM_SAML_CERT_PATH=
NAIPUNYAM_API_BASE_URL=
NAIPUNYAM_API_KEY=

# --- Email (SMTP for verification, password reset) ---
# Local dev:  Mailpit via docker-compose (catches all mail locally)
# Demo:       Resend  (SMTP_HOST=smtp.resend.com PORT=465 USER=resend PASSWORD=re_xxx)
# Production: AWS SES Mumbai
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM=noreply@intants.com
EMAIL_FROM_NAME=Intants AI Interview

# --- Rate limits ---
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=60

# --- Observability ---
SENTRY_DSN=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- DPDP consent ledger (S3-011) ---
# Used to sha256-hash client IPs before storage (DPDP §8 — never store raw PII).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CONSENT_IP_SALT=change-me-to-random-64-char-hex

# --- Exam magic-link (HR workflow Phase 2) ---
# HMAC secret for hashing applicant exam magic-link tokens. MUST be distinct from
# JWT_SECRET. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EXAM_LINK_SECRET=change-me-to-random-64-char-hex
# Public base URL the candidate's browser hits; mint builds {base}/exam#<token>.
EXAM_LINK_BASE_URL=http://localhost:5173
# Magic-link lifetime in hours (default 72).
EXAM_LINK_TTL_HOURS=72

# --- Coding round — sandboxed code execution (HR workflow Phase 2) ---
# Provider is swappable. The free PUBLIC Piston (emkc.org) became whitelist-only
# on 2026-02-15, so SELF-HOST Piston: `scripts/piston-up.ps1` (needs Docker) runs
# it on :2000 and installs the languages. Point PISTON_API_URL at it. Self-hosting
# in Mumbai is also the Tier-2 India-residency path (same var, different URL).
EXECUTION_PROVIDER=piston
PISTON_API_URL=http://localhost:2000/api/v2
# Per-run wall-clock cap (ms). DoS guards: max tests/question, max questions/exam,
# max submitted source bytes. Grading is synchronous (N runs/submit) — keep low.
CODE_RUN_TIMEOUT_MS=5000
CODE_MAX_TEST_CASES=20
CODE_MAX_QUESTIONS_PER_EXAM=20
CODE_MAX_SOURCE_BYTES=64000

# --- Interview invite magic-link (HR workflow Phase 3) ---
# HMAC secret for hashing applicant interview magic-link tokens. MUST be distinct
# from JWT_SECRET and EXAM_LINK_SECRET. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
INTERVIEW_LINK_SECRET=change-me-to-random-64-char-hex
INTERVIEW_LINK_BASE_URL=http://localhost:5173
INTERVIEW_LINK_TTL_HOURS=48

# --- DPDP retention policy (S4-011) ---
# Sessions (+ cascaded turns) with status='completed' older than RETENTION_DAYS
# days are purged daily by the APScheduler cron.  dpdp_consent_ledger is NEVER
# touched by this job — it is the audit trail and must be kept indefinitely.
RETENTION_DAYS=90

# SAFETY RAIL — keep TRUE until a dry-run cycle confirms expected delete counts.
# Flip to false in production only after verifying the dry-run log output.
# DRY_RUN=True: logs would-be deletes, performs NO actual DELETE statement.
# DRY_RUN=False: live deletes execute; turns are removed via ON DELETE CASCADE.
RETENTION_DRY_RUN=true

# UTC hour for the daily cron.  3 = 03:00 UTC ≈ 08:30 IST (off-peak window).
RETENTION_CRON_HOUR=3

# --- Trusted proxy count (S4-012) ---
# Controls how many right-hand hops in X-Forwarded-For belong to trusted
# infrastructure (our proxies), NOT the client. Set incorrectly and IP spoofing
# in the consent ledger becomes trivial.
#
# 0  = local / CI: no reverse proxy; X-Forwarded-For is ignored entirely.
#       Use request.client.host directly. Safe default.
# 1  = Railway demo: one nginx hop sits in front of the FastAPI process.
#       Example: "real-client, 10.railway-internal" → records "real-client".
# 2  = Staging: CDN edge + internal ingress (two infrastructure hops).
#
# NEVER set this higher than the actual number of controlled proxy hops —
# doing so shifts the trusted window into attacker-controlled header entries.
TRUSTED_PROXY_COUNT=0

# --- Object storage for resume/JD uploads (B-031 / B-032) ---
# Local dev: MinIO via docker-compose (S3-compatible, http on :9000).
# Demo:      Cloudflare R2 (S3_ENDPOINT=https://<acct>.r2.cloudflarestorage.com, S3_USE_SSL=true).
# Production: AWS S3 Mumbai (leave S3_ENDPOINT empty, S3_REGION=ap-south-1, S3_USE_SSL=true).
# NOTE: with a custom endpoint (MinIO/R2) the client forces path-style addressing.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto                                  # 'auto' for R2; 'ap-south-1' for AWS S3
S3_BUCKET_NAME=intants-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_USE_SSL=false                                # true for R2 and AWS S3
