# ==============================================================================
# feedback_billing — Scorecards + PDF Generation + Billing Pipeline
# ==============================================================================
# Owns: End-of-session scoring, scorecard PDFs, usage metering, invoicing
# Run:  cd services/feedback_billing && uvicorn app.main:app --reload --port 8003
# Copy this file to .env and fill in real values. NEVER commit .env.
# ==============================================================================

# --- Service identity ---
SERVICE_NAME=feedback_billing
APP_ENV=development
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=8003

# --- Database (Postgres) ---
# Local dev:  docker-compose Postgres
# Demo:       Neon  (postgresql+asyncpg://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/intants?sslmode=require)
# Production: AWS RDS Mumbai
DATABASE_URL=postgresql+asyncpg://intants:intants_dev_pw@localhost:5433/intants_interview
DATABASE_POOL_SIZE=5
# Set to "require" for any cloud/TLS endpoint (Prisma, Neon, RDS).
# asyncpg rejects ?sslmode= query params — SSL is passed via connect_args instead.
# Leave blank for local docker-compose Postgres.
DATABASE_SSL=

# --- Cache (Redis) ---
# Local dev:  docker-compose Redis
# Demo:       Upstash  (rediss://default:pass@xxx.upstash.io:6379/2)
# Production: AWS ElastiCache Mumbai
REDIS_URL=redis://localhost:6379/2

# --- LLM — for scoring against rubric (temperature LOW for consistency) ---
LLM_PROVIDER=gemini                             # gemini | anthropic | bedrock

# Gemini (Google AI Studio)
# Gotchas: 2.0-flash NOT in free tier; 1.5-* deprecated; 2.5-flash is thinking model (need >=256 tokens).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=2048
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Anthropic API (alt — sign up: https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.1
ANTHROPIC_PROMPT_CACHE=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20260201-v1:0

# --- Embeddings (for JD/NOS retrieval used during scoring) ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# --- Object storage for scorecard PDFs (S3-compatible) ---
# Local dev:  MinIO via docker-compose
# Demo:       Cloudflare R2  (S3_ENDPOINT=https://<acct-id>.r2.cloudflarestorage.com)
# Production: AWS S3 Mumbai
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto                                  # 'auto' for R2; 'ap-south-1' for AWS S3
S3_BUCKET_NAME=intants-interview-scorecards
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_USE_SSL=false

# --- Email (deliver scorecards to candidates) ---
# Local dev:  Mailpit
# Demo:       Resend  (SMTP_HOST=smtp.resend.com PORT=465 USER=resend PASSWORD=re_xxx)
# Production: AWS SES Mumbai
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM=noreply@intants.com

# --- Payments (Razorpay — enable when billing goes live) ---
FEATURE_BILLING=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Auth: this service VALIDATES tokens from data_gateway ---
JWT_SECRET=change-me-to-random-64-char-hex
JWT_ALGORITHM=HS256

# --- Observability ---
SENTRY_DSN=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
