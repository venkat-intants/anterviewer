# ==============================================================================
# interview_core — Voice Interview Service
# ==============================================================================
# Owns: LiveKit (real-time WebRTC) transport, LangGraph brain, voice pipeline.
# AVATAR_PROVIDER = tavus | simli | none   |   SPEECH = Sarvam   |   LLM = gemini | groq
# Run:  cd services/interview_core && uvicorn app.main:app --reload --port 8001
# Copy this file to .env and fill in real values. NEVER commit .env.
# ==============================================================================

# --- Service identity ---
SERVICE_NAME=interview_core
# APP_ENV controls security gates. Allowed values: development | staging | production
# In production: ?token= query-param WS auth is disabled (JWT visible in access logs).
APP_ENV=development
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=8001
# Number of trusted reverse proxies in front of this service.
# Set to 0 in local dev (no proxy). Railway/Vercel: 1.
# See app/utils/request_ip.py for extraction logic.
TRUSTED_PROXY_COUNT=1

# --- Database (Postgres) ---
# Local dev:  docker-compose Postgres (default below)
# Demo:       Neon  (postgresql+asyncpg://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/intants?sslmode=require)
# Production: AWS RDS Mumbai
DATABASE_URL=postgresql+asyncpg://intants:intants_dev_pw@localhost:5433/intants_interview
DATABASE_POOL_SIZE=10
# Set to "require" for any cloud/TLS endpoint (Prisma, Neon, RDS).
# asyncpg rejects ?sslmode= query params — SSL is passed via connect_args instead.
# Leave blank for local docker-compose Postgres.
DATABASE_SSL=

# --- Cache (Redis) ---
# Local dev:  docker-compose Redis
# Demo:       Upstash  (rediss://default:pass@xxx.upstash.io:6379)
# Production: AWS ElastiCache Mumbai
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=3600

# --- LLM — swappable provider ---
LLM_PROVIDER=gemini                             # gemini | groq | anthropic | bedrock

# Gemini (Google AI Studio — sign up: https://aistudio.google.com/)
# Model selection gotchas (investigated 2026-05-27):
#   - gemini-2.0-flash : NOT in free tier (limit:0). Requires billing in Google Cloud Console.
#   - gemini-1.5-* : DEPRECATED, removed from v1beta API.
#   - gemini-2.5-flash : Free tier OK. THINKING model — needs GEMINI_MAX_TOKENS >= 256.
#   - gemini-flash-lite-latest : Free tier OK. Non-thinking, smaller budget fine.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=2048
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Groq (fast OpenAI-compatible inference — swap LLM_PROVIDER=groq to activate)
# Sign up: https://console.groq.com/ — free tier, no billing required.
# Model: llama-3.3-70b-versatile gives best quality/speed on free tier.
# An empty key is safe when LLM_PROVIDER=gemini — adapter is not constructed.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic API (alt — sign up: https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TEMPERATURE=0.4
ANTHROPIC_PROMPT_CACHE=true

# AWS Bedrock (prod — India residency)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20260201-v1:0

# --- Speech Provider — SWAPPABLE ---
# Demo:       'sarvam'   (Indian, Indic-focused, instant sign-up)
# Alt demo:   'openai' (Whisper STT) + 'elevenlabs' (TTS) — if Sarvam blocked
# Production: 'bhashini' (Govt of India, free, DPDP-compliant) — when approval lands
SPEECH_STT_PROVIDER=sarvam                      # sarvam | bhashini | openai | google
SPEECH_TTS_PROVIDER=sarvam                      # sarvam | bhashini | elevenlabs | google

# --- Sarvam AI (Indian Indic STT + TTS) ---
# Sign up: https://dashboard.sarvam.ai/
SARVAM_API_KEY=
# saaras:v3 is the current model with mode=transcribe.
# saarika:v2.5 is deprecating per research/sarvam-pricing-2026-05.md §4 — do NOT revert.
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3

# --- OpenAI Whisper (STT fallback) ---
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1

# --- ElevenLabs (TTS fallback) ---
# Sign up: https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_EN=
ELEVENLABS_VOICE_ID_HI=
ELEVENLABS_VOICE_ID_TE=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- Bhashini (Production / when ULCA approval lands) ---
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_INFERENCE_URL=https://meity-auth.ulcacontrib.org/ulca/apis/v0/model/compute
BHASHINI_PIPELINE_ASR_EN=
BHASHINI_PIPELINE_ASR_HI=
BHASHINI_PIPELINE_ASR_TE=
BHASHINI_PIPELINE_TTS_EN=
BHASHINI_PIPELINE_TTS_HI=
BHASHINI_PIPELINE_TTS_TE=

# --- AI4Bharat self-hosted (future, GPU-based) ---
AI4BHARAT_ENABLED=false
AI4BHARAT_ASR_ENDPOINT=
AI4BHARAT_TTS_ENDPOINT=

# --- Object storage for audio recordings (S3-compatible) ---
# Local dev:  MinIO via docker-compose (defaults below)
# Demo:       Cloudflare R2  (S3_ENDPOINT=https://<acct-id>.r2.cloudflarestorage.com)
# Production: AWS S3 Mumbai  (S3_ENDPOINT blank, use AWS_* creds above, region ap-south-1)
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto                                  # 'auto' for R2; 'ap-south-1' for AWS S3
S3_BUCKET_NAME=intants-interview-audio
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_USE_SSL=false                                # true for R2 and AWS S3

# ==============================================================================
# REAL-TIME TRANSPORT + AVATAR (rebuild 2026-05-31 — docs/ARCH-realtime-interview.md)
# D-ID and HeyGen REMOVED. Focus: LiveKit transport + Simli/Tavus avatar (demo).
# ==============================================================================

# --- LiveKit (real-time WebRTC transport) ---
# Demo: LiveKit Cloud free tier. Bid: self-host in Mumbai (same vars, diff URL).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Avatar Provider — SWAPPABLE ---
# 'none'   -> voice-only, no avatar (first real-time milestone)
# 'simli'  -> Simli (demo real-time avatar)
# 'tavus'  -> Tavus (demo real-time avatar; US-hosted, echo-mode persona, no India residency)
# 'custom' -> Tier-2 self-hosted RPM client-side visemes (the BID path)
# DEMO-ONLY for simli/tavus: no India residency + over the ₹12/session cap.
AVATAR_PROVIDER=tavus

# --- Simli (demo real-time avatar) ---
SIMLI_API_KEY=
SIMLI_FACE_ID=
SIMLI_API_BASE_URL=https://api.simli.ai

# --- Tavus (demo real-time avatar; echo mode = Sarvam voice + Tavus face) ---
# TAVUS_REPLICA_ID = the face; TAVUS_PERSONA_ID must be created in echo mode
# (pipeline_mode=echo + transport=livekit) via scripts/tavus_setup.py.
TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=
TAVUS_API_URL=https://tavusapi.com

# --- RPM (Ready Player Me) — Tier-2 bid path (client-side visemes), empty for now ---
RPM_API_KEY=
RPM_PARTNER_SUBDOMAIN=intants

# --- Auth: this service VALIDATES tokens issued by data_gateway ---
JWT_SECRET=change-me-to-random-64-char-hex
JWT_ALGORITHM=HS256
# S3-005: required claims — must match data_gateway values exactly
JWT_ISSUER=intants-data-gateway
JWT_AUDIENCE=intants-services

# --- Feature flags ---
FEATURE_AVATAR_ENABLED=true
FEATURE_VOICE_INTERRUPTION=true
FEATURE_MULTILINGUAL=true

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
