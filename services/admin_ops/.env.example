# ==============================================================================
# admin_ops — Admin Dashboard APIs + Analytics + Ops
# ==============================================================================
# Owns: Read-only analytics, admin user management, ops health endpoints
# Run:  cd services/admin_ops && uvicorn app.main:app --reload --port 8004
# Copy this file to .env and fill in real values. NEVER commit .env.
# ==============================================================================

# --- Service identity ---
SERVICE_NAME=admin_ops
APP_ENV=development
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=8004

# --- Database (Postgres — read-mostly) ---
# Local dev:  docker-compose Postgres
# Demo:       Neon
# Production: AWS RDS Mumbai
DATABASE_URL=postgresql+asyncpg://intants:intants_dev_pw@localhost:5433/intants_interview
DATABASE_POOL_SIZE=5
# Set to "require" for any cloud/TLS endpoint (Prisma, Neon, RDS).
# asyncpg rejects ?sslmode= query params — SSL is passed via connect_args instead.
# Leave blank for local docker-compose Postgres.
DATABASE_SSL=

# --- Cache (Redis) ---
# Local dev:  docker-compose Redis
# Demo:       Upstash
# Production: AWS ElastiCache Mumbai
REDIS_URL=redis://localhost:6379/3

# --- Object storage (S3-compatible) — DPDP erasure file purge ---
# The erasure executor deletes scorecard PDFs/transcripts + resume files to
# fulfil DPDP §12. Leave all blank in local dev/CI — the executor gracefully
# skips S3 deletes when S3_ENDPOINT_URL is empty (logs a warning instead).
# Local dev:  MinIO (S3_ENDPOINT_URL=http://localhost:9000)
# Demo:       Backblaze B2 / Cloudflare R2 (set S3_ENDPOINT_URL)
# Production: AWS S3 Mumbai (leave S3_ENDPOINT_URL empty, set S3_REGION=ap-south-1)
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=auto                                  # 'auto' for R2/B2; 'ap-south-1' for AWS S3
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Bucket holding scorecard PDFs + transcript JSON (written by feedback_billing).
S3_SCORECARD_BUCKET=intants-interview-scorecards
# Bucket holding resume PDFs + JD documents (written by data_gateway).
S3_BUCKET_NAME=intants-uploads

# --- Auth: validate tokens + check admin role ---
JWT_SECRET=change-me-to-random-64-char-hex
JWT_ALGORITHM=HS256

# --- Observability ---
SENTRY_DSN=

# --- CORS (admin panel only) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
