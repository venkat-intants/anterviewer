# ==============================================================================
# web — React 18 + TypeScript + Vite Frontend (PWA)
# ==============================================================================
# Run:  cd web && npm run dev
# WARNING: ALL VITE_* variables are bundled into client-side code and visible
#          in the browser. NEVER put secrets here. Only public values.
# Copy this file to .env and fill in real values. NEVER commit .env.
# ==============================================================================

# --- Backend service endpoints ---
VITE_API_BASE_URL=http://localhost:8002             # data_gateway (auth + users)
VITE_INTERVIEW_API_URL=http://localhost:8001        # interview_core
VITE_FEEDBACK_API_URL=http://localhost:8003         # feedback_billing
VITE_ADMIN_API_URL=http://localhost:8004            # admin_ops

# --- App meta ---
VITE_APP_NAME=Intants AI Interview
VITE_APP_ENV=development

# --- Mock toggle (set to 'true' to use hardcoded API responses, 'false' to hit real backend) ---
VITE_USE_MOCK=false

# Custom avatar (Ready Player Me) — public subdomain only
VITE_RPM_SUBDOMAIN=intants

# --- Observability (public client DSN) ---
VITE_SENTRY_DSN=

# --- Feature flags (mirror backend flags for UI gating) ---
VITE_FEATURE_AVATAR=true
VITE_FEATURE_VOICE_INTERRUPTION=true
VITE_FEATURE_MULTILINGUAL=true
