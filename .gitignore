# LOGS / TEMP
# ==============================================================================
*.log
logs/
tmp/
temp/
*.tmp


# ==============================================================================
# DOCKER / K8S RUNTIME
# ==============================================================================
*.pid
*.sock


# ==============================================================================
# LARGE BINARIES / CACHES (download on demand, don't commit)
# ==============================================================================
assets/avatars/cache/
*.mp3
*.wav
*.webm
*.glb
!web/src/assets/**/*.glb     # except committed sample avatars


# ==============================================================================
# TERRAFORM / IAC STATE
# ==============================================================================
*.tfstate
*.tfstate.*
.terraform/
.terragrunt-cache/


# ==============================================================================
# CLAUDE CODE (keep agents committed, exclude local-only settings)
# ==============================================================================
.claude/settings.local.json


# ==============================================================================
# JUPYTER / NOTEBOOKS (for ad-hoc analysis)
# ==============================================================================
.ipynb_checkpoints/
*.ipynb


# ==============================================================================
# DB DUMPS (these can contain PII — never commit)
# ==============================================================================
*.sql.gz
*.dump
backups/


# ==============================================================================
# IDE-OPENED PLACEHOLDER FILES
# ==============================================================================
Untitled
Untitled.*


# ==============================================================================
# PROJECT-SPECIFIC RUNTIME FILES
